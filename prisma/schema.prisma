generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Branch {
  id        String     @id @default(cuid())
  name      String
  type      BranchType @default(SEATING)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  imageUrl  String?
  floors    Floor[]
  orders    Order[]
  sessions  Session[]

  @@index([type])
}

model User {
  id         String    @id @default(cuid())
  name       String
  email      String    @unique
  username   String?   @unique
  password   String
  role       UserRole  @default(CASHIER)
  otp        String?
  otpExpiry  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  isApproved Boolean   @default(false)
  orders     Order[]
  sessions   Session[]
}

model Category {
  id        String    @id @default(cuid())
  name      String
  color     String    @default("#3b82f6")
  order     Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]

  @@index([order])
}

model Product {
  id               String           @id @default(cuid())
  name             String
  categoryId       String
  price            Float
  tax              Float            @default(0)
  uom              String?          @default("Unit")
  priceTaxIncluded Boolean          @default(true)
  description      String?
  imageUrl         String?
  isAvailable      Boolean          @default(true)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  isVegetarian     Boolean          @default(true)
  orderItems       OrderItem[]
  category         Category         @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  variants         ProductVariant[]

  @@index([categoryId])
  @@index([isAvailable])
}

model ProductVariant {
  id         String      @id @default(cuid())
  productId  String
  attribute  String
  value      String
  extraPrice Float       @default(0)
  orderItems OrderItem[]
  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model Floor {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  branchId  String?
  branch    Branch?  @relation(fields: [branchId], references: [id])
  tables    Table[]

  @@index([branchId])
}

model Table {
  id        String    @id @default(cuid())
  floorId   String
  number    String
  seats     Int       @default(4)
  isActive  Boolean   @default(true)
  isOccupied Boolean  @default(false)
  tableType String?   @default("Table")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  imageUrl  String?
  orders    Order[]
  qrTokens  QRToken[]
  floor     Floor     @relation(fields: [floorId], references: [id], onDelete: Cascade)

  @@index([floorId])
  @@index([isActive])
}

model POSConfig {
  id                 String        @id @default(cuid())
  cashEnabled        Boolean       @default(true)
  digitalEnabled     Boolean       @default(true)
  upiEnabled         Boolean       @default(false)
  upiId              String?
  selfOrderEnabled   Boolean       @default(false)
  selfOrderMode      SelfOrderMode @default(ONLINE_ORDERING)
  bgImageUrl         String?
  updatedAt          DateTime      @updatedAt
  razorpayTerminalId String?
}

model Session {
  id          String    @id @default(cuid())
  userId      String
  openedAt    DateTime  @default(now())
  closedAt    DateTime?
  openingCash Float     @default(0)
  closingCash Float?
  branchId    String?
  orders      Order[]
  branch      Branch?   @relation(fields: [branchId], references: [id])
  user        User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([branchId])
  @@index([openedAt])
}

model Order {
  id          String      @id @default(cuid())
  tableId     String?
  sessionId   String?
  userId      String?
  status      OrderStatus @default(DRAFT)
  total       Float       @default(0)
  note        String?
  isQrOrder   Boolean     @default(false)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  branchId    String?
  customerId  String?
  identifier  String?     @unique
  orderNumber Int         @default(autoincrement())
  branch      Branch?     @relation(fields: [branchId], references: [id])
  customer    Customer?   @relation(fields: [customerId], references: [id])
  session     Session?    @relation(fields: [sessionId], references: [id])
  table       Table?      @relation(fields: [tableId], references: [id])
  user        User?       @relation(fields: [userId], references: [id])
  items       OrderItem[]
  payment     Payment?

  @@index([branchId])
  @@index([status])
  @@index([tableId])
  @@index([createdAt])
}

model OrderItem {
  id          String          @id @default(cuid())
  orderId     String
  productId   String
  variantId   String?
  quantity    Int             @default(1)
  price       Float
  isPrepared  Boolean         @default(false)
  note        String?
  isCancelled Boolean         @default(false)
  status      OrderStatus     @default(SENT)
  order       Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant     ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)
}

model Payment {
  id      String        @id @default(cuid())
  orderId String        @unique
  method  PaymentMethod
  amount  Float
  paidAt  DateTime      @default(now())
  order   Order         @relation(fields: [orderId], references: [id])
}

model QRToken {
  id        String   @id @default(cuid())
  tableId   String
  token     String   @unique @default(cuid())
  createdAt DateTime @default(now())
  table     Table    @relation(fields: [tableId], references: [id], onDelete: Cascade)
}

model Customer {
  id        String   @id @default(cuid())
  name      String
  phone     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  orders    Order[]

  @@index([phone])
}

enum UserRole {
  ADMIN
  CASHIER
  KITCHEN
}

enum OrderStatus {
  DRAFT
  SENT
  PREPARING
  READY
  PAID
  CANCELLED
  DELIVERED
}

enum PaymentMethod {
  CASH
  DIGITAL
  UPI
}

enum SelfOrderMode {
  ONLINE_ORDERING
  QR_MENU
}

enum BranchType {
  SEATING
  TAKEAWAY
  MIXED
}
